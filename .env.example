# Optional: LLM screening (tool opportunity vs news). See README.
# Use bare names (common) or IDEAS_* — both work.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# IDEAS_LLM_PROVIDER=openai
# IDEAS_OPENAI_API_KEY=
# IDEAS_OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible API root (must be reachable). Default: https://api.openai.com/v1
# Local proxy must be running; unset this to use the cloud API:
# IDEAS_OPENAI_BASE_URL=https://api.openai.com/v1
# IDEAS_GEMINI_API_KEY=
# IDEAS_GEMINI_MODEL=gemini-2.0-flash
# IDEAS_LLM_MIN_TOOL_SCORE=0.60
# IDEAS_LLM_SCREEN_MIN_EMBED_FIT=0.35
# IDEAS_LLM_MAX_ITEMS_PER_RUN=0
# IDEAS_LLM_SLEEP_SECONDS=0.12

# Niche B2B: prefer targeted forums over only broad tech news.
# Stack Exchange — comma-separated site slugs (see stackexchange.com/sites)
# IDEAS_STACKEXCHANGE_SITES=workplace,serverfault,dba,salesforce,sharepoint
# Reddit — comma-separated subreddit names (requires IDEAS_REDDIT_* below)
# IDEAS_REDDIT_SUBREDDITS=smallbusiness,sysadmin,accounting,ecommerce,msp
# Discourse — comma-separated origins with public /latest.json
# IDEAS_DISCOURSE_BASE_URLS=https://meta.discourse.org

# Default pipeline: Hacker News + Stack Exchange only (no keys required).
# dev.to — included in default `ideas ingest` (HN+SE+dev.to). Optional token: dev.to → Settings → Extensions
# IDEAS_DEVTO_TOKEN=
# IDEAS_DEVTO_ARTICLES_LIMIT=30
# RSS — no key; comma-separated Atom/RSS URLs (company blogs, Substack: https://<name>.substack.com/feed)
# Default in app includes Lobsters; add e.g. Stack Overflow blog, GitHub blog, engineering blogs:
# IDEAS_RSS_FEED_URLS=https://lobste.rs/h.rss,https://stackoverflow.blog/feed/,https://github.blog/feed/
# IDEAS_RSS_MAX_ENTRIES_PER_FEED=25
# GitHub — optional (`ideas ingest -s all` or `-s github`). Public repos work without a token (low rate limits).
# IDEAS_GITHUB_TOKEN=
# IDEAS_GITHUB_REPOS=octocat/Hello-World
# IDEAS_GITHUB_ISSUES_PER_REPO=25
# GitLab — public API, no token; optional GITLAB_TOKEN for limits/private
# IDEAS_GITLAB_HOST=https://gitlab.com
# IDEAS_GITLAB_PROJECTS=gitlab-org/gitlab
# IDEAS_GITLAB_ISSUES_PER_PROJECT=20
# IDEAS_GITLAB_TOKEN=
# Discourse — public /latest.json
# IDEAS_DISCOURSE_BASE_URLS=https://meta.discourse.org
# IDEAS_DISCOURSE_TOPICS_PER_SITE=25
# Mastodon — public hashtag timelines
# IDEAS_MASTODON_HOST=mastodon.social
# IDEAS_MASTODON_HASHTAGS=dev,sre
# IDEAS_MASTODON_LIMIT=40
# Lemmy — public /api/v3/post/list
# IDEAS_LEMMY_HOST=lemmy.ml
# IDEAS_LEMMY_COMMUNITY=
# IDEAS_LEMMY_LIMIT=25
# Reddit — add these when you’re ready (optional).
# IDEAS_REDDIT_CLIENT_ID=
# IDEAS_REDDIT_CLIENT_SECRET=
# IDEAS_REDDIT_USER_AGENT=ideas-generator/0.1

# Ingest time window (UTC): only items newer than now - N seconds are kept (all sources).
# Default 604800 = 7 days — fits a weekly cron. Use 0 to disable filtering.
IDEAS_INGEST_LOOKBACK_SECONDS=604800
# Deprecated: if set, overrides IDEAS_INGEST_LOOKBACK_SECONDS for HN + filter.
# IDEAS_HN_LOOKBACK_SECONDS=

# SQLite path (default: data/ideas.sqlite3)
IDEAS_DATABASE_PATH=data/ideas.sqlite3

# Embedding model (fastembed; keep stable for comparable clusters)
IDEAS_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# “Business tool opportunity” gate: cosine similarity vs anchor (embedding space).
# Lower = more posts; higher = stricter B2B/tool fit. Set to 0 to disable.
IDEAS_MIN_BUSINESS_TOOL_FIT=0.48

# Optional: override anchor text (long string). Default is in ideas_generator/config.py.
# IDEAS_BUSINESS_TOOL_ANCHOR=

# Clustering: cosine similarity threshold [0,1]
IDEAS_CLUSTER_SIMILARITY_THRESHOLD=0.80

# Scoring weights (defaults in Settings)
# IDEAS_WEIGHT_RECURRENCE=1.0
# IDEAS_WEIGHT_RECENCY=0.5
# ...
